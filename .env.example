# Copy to .env and fill in as needed. secmend reads keys from the environment only.
# .env is git-ignored. NEVER commit real keys.

# Default provider: claude | openai | ollama | mock
SECMEND_PROVIDER=claude

# Optional model override
# SECMEND_MODEL=claude-opus-4-8

# Provider credentials (only the one you use)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Ollama endpoint (if not default)
# OLLAMA_HOST=http://localhost:11434
